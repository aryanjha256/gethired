DATABASE_URL=postgresql://user:password@host:5432/dbname

# Only this email is allowed past the auth gate; anyone else can sign in via
# Clerk but lands on /not-authorized.
ALLOWED_EMAIL=you@example.com

# Gmail: smtp.gmail.com, port 465. SMTP_PASSWORD is an app password
# (Google Account > Security > 2-Step Verification > App passwords), not your
# regular login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-character-app-password
SMTP_FROM_NAME=Your Name
