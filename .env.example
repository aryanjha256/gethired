DATABASE_URL=postgresql://user:password@host:5432/dbname

# Only this email is allowed past the auth gate; anyone else can sign in via
# Clerk but lands on /not-authorized.
ALLOWED_EMAIL=you@example.com

# Gmail: smtp.gmail.com, port 465. SMTP_PASSWORD is an app password
# (Google Account > Security > 2-Step Verification > App passwords), not your
# regular login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-character-app-password
SMTP_FROM_NAME=Your Name

# Gmail IMAP, used only to check the inbox for replies (reuses SMTP_USER /
# SMTP_PASSWORD above — the same app password works for both). IMAP must
# also be turned on separately in Gmail Settings > Forwarding and POP/IMAP.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# Verifies that GET /api/emails/drain was actually called by Vercel Cron
# (see vercel.json) and not some other request — proxy.ts's matcher
# excludes /api entirely, so nothing else protects this route. Vercel sets
# this automatically as an env var on the project and attaches it as the
# Authorization header on cron-triggered requests; generate any random
# string for local/dev use (e.g. `openssl rand -hex 32`).
CRON_SECRET=your-random-secret
